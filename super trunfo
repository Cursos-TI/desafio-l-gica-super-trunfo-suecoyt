#include <stdio.h>

int main() {
    // ===================== VARIÁVEIS - CARTA 1 =====================
    char codigo1[5];
    char nomeCidade1[50];
    int populacao1;
    float area1;
    float pib1;
    int pontosTuristicos1;
    float densidadePopulacional1;
    float pibPerCapita1;

    // ===================== VARIÁVEIS - CARTA 2 =====================
    char codigo2[5];
    char nomeCidade2[50];
    int populacao2;
    float area2;
    float pib2;
    int pontosTuristicos2;
    float densidadePopulacional2;
    float pibPerCapita2;

    // ===================== CADASTRO DA CARTA 1 =====================
    printf("===== Cadastro da Carta 1 =====\n");

    printf("Digite o codigo da cidade: ");
    scanf("%s", codigo1);

    printf("Digite o nome da cidade: ");
    scanf(" %[^\n]", nomeCidade1);

    printf("Digite a populacao: ");
    scanf("%d", &populacao1);

    printf("Digite a area (em km2): ");
    scanf("%f", &area1);

    printf("Digite o PIB (em bilhoes): ");
    scanf("%f", &pib1);

    printf("Digite o numero de pontos turisticos: ");
    scanf("%d", &pontosTuristicos1);

    // ===================== CADASTRO DA CARTA 2 =====================
    printf("\n===== Cadastro da Carta 2 =====\n");

    printf("Digite o codigo da cidade: ");
    scanf("%s", codigo2);

    printf("Digite o nome da cidade: ");
    scanf(" %[^\n]", nomeCidade2);

    printf("Digite a populacao: ");
    scanf("%d", &populacao2);

    printf("Digite a area (em km2): ");
    scanf("%f", &area2);

    printf("Digite o PIB (em bilhoes): ");
    scanf("%f", &pib2);

    printf("Digite o numero de pontos turisticos: ");
    scanf("%d", &pontosTuristicos2);

    // ===================== CALCULOS DERIVADOS =====================
    densidadePopulacional1 = populacao1 / area1;
    densidadePopulacional2 = populacao2 / area2;

    // PIB cadastrado em bilhoes, multiplicamos por 1e9 para obter PIB per capita em valor "cheio"
    pibPerCapita1 = (pib1 * 1000000000) / populacao1;
    pibPerCapita2 = (pib2 * 1000000000) / populacao2;

    // ===================== COMPARACAO DAS CARTAS =====================
    printf("\n===== Resultado da Comparacao =====\n");

    // ---------- Populacao ----------
    printf("\n-- Populacao --\n");
    if (populacao1 > populacao2) {
        printf("%s venceu! (Populacao: %d vs %d)\n", nomeCidade1, populacao1, populacao2);
    } else if (populacao1 < populacao2) {
        printf("%s venceu! (Populacao: %d vs %d)\n", nomeCidade2, populacao2, populacao1);
    } else {
        printf("Empate! Ambas as cidades tem a mesma populacao (%d).\n", populacao1);
    }

    // ---------- Area ----------
    printf("\n-- Area --\n");
    if (area1 > area2) {
        printf("%s venceu! (Area: %.2f vs %.2f km2)\n", nomeCidade1, area1, area2);
    } else if (area1 < area2) {
        printf("%s venceu! (Area: %.2f vs %.2f km2)\n", nomeCidade2, area2, area1);
    } else {
        printf("Empate! Ambas as cidades tem a mesma area (%.2f km2).\n", area1);
    }

    // ---------- PIB ----------
    printf("\n-- PIB --\n");
    if (pib1 > pib2) {
        printf("%s venceu! (PIB: %.2f vs %.2f bilhoes)\n", nomeCidade1, pib1, pib2);
    } else if (pib1 < pib2) {
        printf("%s venceu! (PIB: %.2f vs %.2f bilhoes)\n", nomeCidade2, pib2, pib1);
    } else {
        printf("Empate! Ambas as cidades tem o mesmo PIB (%.2f bilhoes).\n", pib1);
    }

    // ---------- Pontos Turisticos ----------
    printf("\n-- Pontos Turisticos --\n");
    if (pontosTuristicos1 > pontosTuristicos2) {
        printf("%s venceu! (Pontos turisticos: %d vs %d)\n", nomeCidade1, pontosTuristicos1, pontosTuristicos2);
    } else if (pontosTuristicos1 < pontosTuristicos2) {
        printf("%s venceu! (Pontos turisticos: %d vs %d)\n", nomeCidade2, pontosTuristicos2, pontosTuristicos1);
    } else {
        printf("Empate! Ambas as cidades tem o mesmo numero de pontos turisticos (%d).\n", pontosTuristicos1);
    }

    // ---------- Densidade Populacional ----------
    printf("\n-- Densidade Populacional --\n");
    if (densidadePopulacional1 > densidadePopulacional2) {
        printf("%s venceu! (Densidade: %.2f vs %.2f hab/km2)\n", nomeCidade1, densidadePopulacional1, densidadePopulacional2);
    } else if (densidadePopulacional1 < densidadePopulacional2) {
        printf("%s venceu! (Densidade: %.2f vs %.2f hab/km2)\n", nomeCidade2, densidadePopulacional2, densidadePopulacional1);
    } else {
        printf("Empate! Ambas as cidades tem a mesma densidade populacional.\n");
    }

    // ---------- PIB per Capita ----------
    printf("\n-- PIB per Capita --\n");
    if (pibPerCapita1 > pibPerCapita2) {
        printf("%s venceu! (PIB per capita: %.2f vs %.2f)\n", nomeCidade1, pibPerCapita1, pibPerCapita2);
    } else if (pibPerCapita1 < pibPerCapita2) {
        printf("%s venceu! (PIB per capita: %.2f vs %.2f)\n", nomeCidade2, pibPerCapita2, pibPerCapita1);
    } else {
        printf("Empate! Ambas as cidades tem o mesmo PIB per capita.\n");
    }

    // ===================== RESULTADO GERAL (CONTAGEM DE VITORIAS) =====================
    int vitorias1 = 0;
    int vitorias2 = 0;

    if (populacao1 > populacao2) vitorias1++; else if (populacao2 > populacao1) vitorias2++;
    if (area1 > area2) vitorias1++; else if (area2 > area1) vitorias2++;
    if (pib1 > pib2) vitorias1++; else if (pib2 > pib1) vitorias2++;
    if (pontosTuristicos1 > pontosTuristicos2) vitorias1++; else if (pontosTuristicos2 > pontosTuristicos1) vitorias2++;
    if (densidadePopulacional1 > densidadePopulacional2) vitorias1++; else if (densidadePopulacional2 > densidadePopulacional1) vitorias2++;
    if (pibPerCapita1 > pibPerCapita2) vitorias1++; else if (pibPerCapita2 > pibPerCapita1) vitorias2++;

    printf("\n===== Placar Final =====\n");
    printf("%s venceu %d categoria(s).\n", nomeCidade1, vitorias1);
    printf("%s venceu %d categoria(s).\n", nomeCidade2, vitorias2);

    if (vitorias1 > vitorias2) {
        printf("\nA carta vencedora geral e: %s\n", nomeCidade1);
    } else if (vitorias2 > vitorias1) {
        printf("\nA carta vencedora geral e: %s\n", nomeCidade2);
    } else {
        printf("\nResultado geral: EMPATE entre %s e %s!\n", nomeCidade1, nomeCidade2);
    }

    return 0;
}
